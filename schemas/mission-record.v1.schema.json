{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/libre-ai/agent-board/schemas/mission-record.v1.schema.json",
  "title": "Libre AI Agent Board MissionRecord v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "mission_id",
    "revision",
    "state",
    "intent",
    "scope",
    "risk",
    "requested_by",
    "acceptance_conditions",
    "approvals",
    "events",
    "blockers",
    "reported_activity"
  ],
  "properties": {
    "format": { "const": "libre-ai.agent-board.mission-record.v1" },
    "mission_id": { "type": "string", "pattern": "^mission-[a-z0-9][a-z0-9-]{2,63}$" },
    "revision": { "type": "integer", "minimum": 1 },
    "state": {
      "enum": [
        "proposed",
        "awaiting_approval",
        "approved",
        "running",
        "blocked",
        "result_submitted",
        "accepted",
        "refused",
        "abandoned"
      ]
    },
    "intent": { "type": "string", "minLength": 10, "maxLength": 500 },
    "scope": { "$ref": "#/$defs/scope" },
    "risk": { "$ref": "#/$defs/risk" },
    "requested_by": { "$ref": "#/$defs/actor" },
    "acceptance_conditions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/acceptanceCondition" }
    },
    "approvals": {
      "type": "array",
      "items": { "$ref": "#/$defs/approval" }
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/event" }
    },
    "blockers": {
      "type": "array",
      "items": { "$ref": "#/$defs/blocker" }
    },
    "reported_activity": {
      "type": "array",
      "items": { "$ref": "#/$defs/activity" }
    },
    "execution_ref": {
      "type": ["string", "null"],
      "pattern": "^agent-factory-run:[A-Za-z0-9._:-]+$"
    },
    "result": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/result" }
      ]
    },
    "human_verdict": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/verdict" }
      ]
    }
  },
  "$defs": {
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor_id", "kind"],
      "properties": {
        "actor_id": { "type": "string", "pattern": "^(human|service):[A-Za-z0-9._:-]+$" },
        "kind": { "enum": ["human", "service"] }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["in_scope", "out_of_scope"],
      "properties": {
        "in_scope": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 3 } },
        "out_of_scope": { "type": "array", "items": { "type": "string", "minLength": 3 } }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "reasons"],
      "properties": {
        "level": { "enum": ["low", "medium", "high", "critical"] },
        "reasons": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 5 } }
      }
    },
    "acceptanceCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["condition_id", "description", "evidence_required"],
      "properties": {
        "condition_id": { "type": "string", "pattern": "^ac-[a-z0-9-]+$" },
        "description": { "type": "string", "minLength": 5 },
        "evidence_required": { "type": "boolean" }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approval_id", "decision", "actor", "at", "reason"],
      "properties": {
        "approval_id": { "type": "string", "pattern": "^approval-[a-z0-9-]+$" },
        "decision": { "enum": ["approved", "refused", "revoked"] },
        "actor": { "$ref": "#/$defs/actor" },
        "at": { "type": "string", "format": "date-time" },
        "reason": { "type": "string", "minLength": 5 }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sequence", "event_id", "from", "to", "actor", "at", "reason"],
      "properties": {
        "sequence": { "type": "integer", "minimum": 1 },
        "event_id": { "type": "string", "pattern": "^event-[a-z0-9-]+$" },
        "from": {
          "type": ["string", "null"],
          "enum": [null, "proposed", "awaiting_approval", "approved", "running", "blocked", "result_submitted", "accepted", "refused", "abandoned"]
        },
        "to": { "enum": ["proposed", "awaiting_approval", "approved", "running", "blocked", "result_submitted", "accepted", "refused", "abandoned"] },
        "actor": { "$ref": "#/$defs/actor" },
        "at": { "type": "string", "format": "date-time" },
        "reason": { "type": "string", "minLength": 5 }
      }
    },
    "blocker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blocker_id", "status", "description", "raised_by", "raised_at"],
      "properties": {
        "blocker_id": { "type": "string", "pattern": "^blocker-[a-z0-9-]+$" },
        "status": { "enum": ["open", "resolved"] },
        "description": { "type": "string", "minLength": 5 },
        "raised_by": { "$ref": "#/$defs/actor" },
        "raised_at": { "type": "string", "format": "date-time" },
        "resolution": { "type": ["string", "null"] }
      }
    },
    "activity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["activity_id", "reported_by", "at", "summary"],
      "properties": {
        "activity_id": { "type": "string", "pattern": "^activity-[a-z0-9-]+$" },
        "reported_by": { "$ref": "#/$defs/actor" },
        "at": { "type": "string", "format": "date-time" },
        "summary": { "type": "string", "minLength": 5 }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "evidence_refs", "submitted_by", "submitted_at"],
      "properties": {
        "summary": { "type": "string", "minLength": 5 },
        "evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 3 } },
        "submitted_by": { "$ref": "#/$defs/actor" },
        "submitted_at": { "type": "string", "format": "date-time" }
      }
    },
    "verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "actor", "at", "reason"],
      "properties": {
        "decision": { "enum": ["accepted", "refused"] },
        "actor": { "$ref": "#/$defs/actor" },
        "at": { "type": "string", "format": "date-time" },
        "reason": { "type": "string", "minLength": 5 }
      }
    }
  }
}
